# Variáveis de Ambiente — ABC Master E-commerce
# Copie este arquivo para .env.local e preencha os valores
# Para produção, configure essas variáveis no painel da Vercel

# ─── Banco de Dados ───────────────────────────────────────────
# Render PostgreSQL (https://render.com) — External Database URL
# Formato: postgresql://usuario:senha@hostname.render.com/abcmaster
DATABASE_URL="postgresql://usuario:senha@host/abcmaster"

# ─── NextAuth.js ──────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="sua-chave-secreta-aqui"
NEXTAUTH_URL="http://localhost:3000"

# ─── Mercado Pago ─────────────────────────────────────────────
# Obtido em: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN="TEST-xxxxxxxxxxxxxxxxxxxx"        # Use TEST- para sandbox
MP_PUBLIC_KEY="TEST-xxxxxxxxxxxxxxxxxxxx"
MP_WEBHOOK_SECRET="sua-webhook-secret"

# URL base da aplicação (para back_urls e webhook do MP)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── Bling ERP ────────────────────────────────────────────────
# Crie em: Bling → Preferências → Cadastro de Aplicativos
BLING_CLIENT_ID="seu-client-id"
BLING_CLIENT_SECRET="seu-client-secret"

# ─── Admin ────────────────────────────────────────────────────
# Email e senha do primeiro usuário administrador
ADMIN_EMAIL="admin@abcmasterembalagens.com.br"
ADMIN_PASSWORD="senha-segura-aqui"
